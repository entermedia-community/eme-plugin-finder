-XX:+ShowCodeDetailsInExceptionMessages
-Dcatalina.home=$EMELIB/tomcat/
-Dcatalina.base=$EMSERVER/tomcat
-Djava.io.tmpdir=$EMSERVER/tomcat/work
-Dfile.encoding=UTF-8
-Dstdout.encoding=UTF-8
-Dstderr.encoding=UTF-8
-DEMELIB=$EMELIB
-cp $EMELIB/bin:$EMSERVER/bin:$EMELIB/tomcat/bin/*:$EMELIB/tomcat/lib/*:$EMELIB/skills/openedit/lib/*:$EMELIB/skills/openinstitute/lib/*:$EMELIB/skills/system/lib/*:$EMELIB/skills/system/lib/compile/*:$EMELIB/skills/finder/lib/*:$EMELIB/skills/manager/lib/*:$EMELIB/skills/mediadb/lib/*
